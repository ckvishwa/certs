# ---------------------------------------------------------------------------
# CERTFORGE AI — environment variables
# Copy to .env.local and fill in real values. .env.local is gitignored.
# ---------------------------------------------------------------------------

# --- Supabase (hosted project: https://app.supabase.com → Project Settings → API) ---
# Browser-safe public values ONLY (these two are the only NEXT_PUBLIC Supabase vars):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Server-only secret. NEVER prefix with NEXT_PUBLIC. Used ONLY by the local seed
# script (node), never bundled to the browser. Lives only in .env.local (gitignored).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key

# --- AI provider ---
# Which provider the abstraction uses by default: "openai" | "anthropic"
AI_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# Optional — only needed if AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
